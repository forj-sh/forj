# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
API_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# JWT Authentication
# Generate a secure random secret: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-replace-with-random-string

# Mock Authentication (Development Only)
# SECURITY: NEVER set to 'true' in production
# When enabled, allows /auth/cli endpoint to issue mock JWT tokens without real authentication
# In production (NODE_ENV=production), this endpoint is always disabled regardless of this setting
# Default: false (secure by default - requires explicit opt-in)
ENABLE_MOCK_AUTH=false

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/database

# Redis (Upstash or local)
REDIS_URL=redis://localhost:6379

# Namecheap Reseller API
# For development: create a free sandbox account at sandbox.namecheap.com
# For production: requires $50 deposit or 20+ domains for reseller activation
NAMECHEAP_API_USER=your_namecheap_username
NAMECHEAP_API_KEY=your_api_key
NAMECHEAP_USERNAME=your_namecheap_username
NAMECHEAP_CLIENT_IP=127.0.0.1
NAMECHEAP_SANDBOX=true

# Stripe
# Get keys from https://dashboard.stripe.com/apikeys
# Webhook secret is generated when you create a webhook endpoint
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# URLs for checkout success/cancel redirects
STRIPE_SUCCESS_URL=https://forj.sh/success
STRIPE_CANCEL_URL=https://forj.sh/cancel

# Cloudflare Integration
# Generate encryption key: openssl rand -base64 32
# Used to encrypt/decrypt Cloudflare API tokens stored in database
# IMPORTANT: Must be a base64-encoded 32-byte (256-bit) key
CLOUDFLARE_ENCRYPTION_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# GitHub OAuth App
# Create OAuth App at github.com/settings/developers
# Callback URL: not required for Device Flow
# Scopes: repo, read:org (configured in code)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# GitHub Token Encryption (Stack 7: Service-specific encryption keys)
# Generate encryption key: openssl rand -base64 32
# Used to encrypt/decrypt GitHub access tokens stored in database
# SECURITY: Separate from Cloudflare key for security isolation
# IMPORTANT: Must be a base64-encoded 32-byte (256-bit) key
GITHUB_ENCRYPTION_KEY=BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=

# Domain Worker
DOMAIN_WORKER_CONCURRENCY=5

# Rate Limiting
RATE_LIMITING_ENABLED=false
RATE_LIMITING_MAX_REQUESTS=100

# Bull Board UI (set to 'true' to enable queue monitoring dashboard)
# WARNING: Bull Board has no authentication - only enable in secure local/dev environments
ENABLE_BULL_BOARD=false

# Payment Verification (Production Security)
# SECURITY: In production (NODE_ENV=production), payment verification is always enforced
# In development, set to 'true' to test payment verification logic
# When enabled, domain registration requires a paid Stripe checkout session
REQUIRE_PAYMENT=false

# Proxy Trust Configuration (Production Security)
# SECURITY: Set to 'true' when behind reverse proxy (Cloudflare, Vercel, nginx)
# When enabled, Fastify trusts X-Forwarded-For and CF-Connecting-IP headers for client IP identification
# When disabled, prevents IP spoofing via forged proxy headers in direct connections
# Production behind Cloudflare: TRUST_PROXY=true (enables CF-Connecting-IP header trust)
# Development/local: TRUST_PROXY=false (default - ignores all proxy headers)
TRUST_PROXY=false
