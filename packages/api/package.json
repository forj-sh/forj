{
  "name": "@forj/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Forj API server",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "db:migrate": "node-pg-migrate up",
    "db:migrate:create": "node-pg-migrate create"
  },
  "dependencies": {
    "@bull-board/api": "^5.14.2",
    "@bull-board/fastify": "^5.14.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@forj/shared": "*",
    "@neondatabase/serverless": "^1.0.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.9",
    "dotenv": "^17.3.1",
    "fastify": "^4.26.1",
    "ioredis": "^5.3.2",
    "jose": "^6.2.1",
    "node-pg-migrate": "^7.0.2",
    "pg": "^8.11.3",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "stripe": "^20.4.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
