    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "eventsource": "^2.0.2",
    "inquirer": "^9.3.8",
    "open": "^11.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/eventsource": "^1.1.15",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.19",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
