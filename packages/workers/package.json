{
  "name": "@forj/workers",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Forj BullMQ workers — Service provisioning workers",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/start-workers.js",
    "start:dev": "tsup --watch & sleep 2 && node dist/start-workers.js",
    "type-check": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch"
  },
  "dependencies": {
    "@forj/shared": "*",
    "@neondatabase/serverless": "^1.0.2",
    "bullmq": "^5.1.0",
    "dotenv": "^17.3.1",
    "ioredis": "^5.3.2",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
