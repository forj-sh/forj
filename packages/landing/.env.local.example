# Cloudflare Turnstile Site Key (optional - spam protection)
# Get your free site key at https://dash.cloudflare.com/
VITE_TURNSTILE_SITEKEY=your_cloudflare_turnstile_sitekey_here

# Cloudflare Turnstile Secret Key (server-side verification)
# Get this from the same Turnstile site configuration
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key_here

# Resend API Key (optional - email confirmations)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# Database Connection (required for production)
# Neon PostgreSQL connection string
DATABASE_URL=postgres://user:password@host/database?sslmode=require
